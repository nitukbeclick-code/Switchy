# ── Dart / Flutter tooling ────────────────────────────────────────────────────
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
# pubspec.lock is committed (Flutter guidance for apps) so CI and release
# builds resolve the exact same dependency set as local dev.

# ── Build outputs ─────────────────────────────────────────────────────────────
build/
*.apk
*.aab
*.ipa
*.dSYM.zip
*.dSYM

# ── IntelliJ / Android Studio ─────────────────────────────────────────────────
*.iml
*.ipr
*.iws
.idea/
.gradle/

# ── Android ───────────────────────────────────────────────────────────────────
android/local.properties
android/.gradle/
android/app/debug/
android/app/profile/
android/app/release/
android/captures/

# ── iOS / macOS ───────────────────────────────────────────────────────────────
ios/Pods/
ios/.symlinks/
ios/Flutter/App.framework
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec
ios/Flutter/Generated.xcconfig
ios/Flutter/ephemeral/
ios/Runner.xcworkspace/xcshareddata/WorkspaceSettings.xcsettings
macos/Pods/
macos/.symlinks/
macos/Flutter/ephemeral/

# ── macOS system ──────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Editor configs ────────────────────────────────────────────────────────────
*.swp
*.swo
*~
.vscode/

# ── Secrets / env ─────────────────────────────────────────────────────────────
.env
.env.*
*.pem
*.p12
*.jks
google-services.json
GoogleService-Info.plist
# Build-time Supabase config (real values). The committed
# dart_define.example.json is the template; copy it to dart_define.json.
/dart_define.json

# ── Supabase CLI ──────────────────────────────────────────────────────────────
supabase/.branches/
supabase/.temp/
supabase/.env
supabase/functions/.env
supabase/functions/**/.env
# but keep committed env *templates* (the .env.* rule above would hide them)
!**/.env.example

# ── Local scratch (prototype dumps, chat logs — never ship) ───────────────────
project/
chats/

# ── Coverage ──────────────────────────────────────────────────────────────────
coverage/
lcov.info

# ── Node.js ───────────────────────────────────────────────────────────────────
node_modules/
package-lock.json

# ── Claude Code ───────────────────────────────────────────────────────────────
# Keep settings.json and the SessionStart hook tracked so web sessions are
# reproducible; ignore only local overrides and transient worktrees.
.claude/settings.local.json
.claude/worktrees/
