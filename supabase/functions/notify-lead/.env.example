# Secrets for the notify-lead Edge Function.
# Set these in the dashboard (Project Settings → Edge Functions → Secrets) or via
#   supabase secrets set --env-file supabase/functions/notify-lead/.env
# The function also accepts several name variants (see firstEnv() in index.ts).
# NEVER commit real values — copy to .env (gitignored) and fill them in.

# Telegram — REQUIRED for the Telegram path
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
TELEGRAM_CHAT_ID=-1001234567890        # team group/channel/DM id (see ?action=telegram-chats)

# Shared secret between the leads trigger and this function — REQUIRED.
# Must match the value stored in Vault (vault.secrets 'lead_webhook_secret').
LEAD_WEBHOOK_SECRET=replace-with-the-value-stored-in-vault

# Resend — OPTIONAL (email path). Needs a Resend-verified sender domain.
RESEND_API_KEY=re_your_resend_key
RESEND_FROM=חוסך <leads@your-verified-domain.co.il>
LEADS_NOTIFY_EMAIL=team@your-domain.co.il

# AI triage — OPTIONAL (one of these enables the smart one-line summary)
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Zoom Server-to-Server OAuth — OPTIONAL (auto-creates the meeting on ✅ אשר;
# without it the bot falls back to asking for a link in chat). Vault names:
# zoom_account_id / zoom_client_id / zoom_client_secret / zoom_host_email.
ZOOM_ACCOUNT_ID=your-zoom-account-id
ZOOM_CLIENT_ID=your-zoom-s2s-client-id
ZOOM_CLIENT_SECRET=your-zoom-s2s-client-secret
# Host user for the created meetings — OPTIONAL; defaults to the token's own
# user ('me'), which some S2S account configurations reject.
# ZOOM_HOST_EMAIL=rep@your-domain.co.il
