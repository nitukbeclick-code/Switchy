# Secrets for the site-subscribe Edge Function (newsletter signup).
# Set these in the dashboard (Project Settings → Edge Functions → Secrets) or via
#   supabase secrets set --env-file supabase/functions/site-subscribe/.env
# NEVER commit real values — copy to .env (gitignored) and fill them in.

# Service-role access for the newsletter_subscribers insert + per-IP rate-limit
# read. SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY are injected automatically in
# the Supabase runtime, so you usually don't need to set them by hand.
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Resend — OPTIONAL (welcome email). If unset, the subscription is still
# recorded; only the welcome email is skipped (fail-soft).
RESEND_API_KEY=re_your_resend_key
# From-address — defaults to "Switchy AI <noreply@switchy-ai.com>" if unset.
# Must be a Resend-verified sender domain.
RESEND_FROM=Switchy AI <noreply@your-verified-domain.com>

# Branded email template (_shared/email.ts) — ALL OPTIONAL, sensible defaults.
# Footer/links + §30A compliance for the welcome (and shared by renewal/lead
# templates). Override only if your domain or legal identity differs.
# SITE_BASE_URL=https://switchy-ai.com            # CTA + compare links + privacy host
# PRIVACY_URL=https://switchy-ai.com/privacy.html # explicit privacy-policy link
# EMAIL_SENDER_IDENTITY=Switchy AI · hello@switchy-ai.com  # footer sender ID (§30A)
# EMAIL_UNSUBSCRIBE_TO=unsubscribe@switchy-ai.com # mailbox the הסר/unsubscribe goes to
# UNSUBSCRIBE_URL=https://switchy-ai.com/unsubscribe  # hosted one-click endpoint (if any);
#                                                 # falls back to a mailto: when unset
