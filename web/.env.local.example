# ════════════════════════════════════════════════════════════════════════════
# Environment variables for the חוסך / Switchy GEO web app.
# Copy to `.env.local` and fill in REAL values locally / in your host's secret
# store. NEVER commit real secrets. The build itself needs NO secrets (catalogue
# is bundled); these are only for the server-side lead API + optional tracking.
# ════════════════════════════════════════════════════════════════════════════

# ── Supabase (lead capture) ──────────────────────────────────────────────────
# Public project URL. Safe to expose to the browser (NEXT_PUBLIC_*).
# Project ref: orzitfqmlvopujsoyigr
NEXT_PUBLIC_SUPABASE_URL=https://orzitfqmlvopujsoyigr.supabase.co

# Service-role key — SERVER ONLY. Used exclusively by /api/lead to INSERT into
# public.leads (bypasses RLS). MUST NOT be prefixed NEXT_PUBLIC_ and MUST NEVER
# reach the browser. Leave blank in any client-exposed context.
SUPABASE_SERVICE_ROLE_KEY=

# ── Meta (Facebook) Pixel — OPTIONAL ─────────────────────────────────────────
# Pixel id for the 'Lead' conversion event. If unset, Meta tracking no-ops.
NEXT_PUBLIC_FB_PIXEL_ID=
