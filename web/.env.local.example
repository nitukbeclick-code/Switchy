# ════════════════════════════════════════════════════════════════════════════
# Environment variables for the חוסך / Switchy GEO web app.
# Copy to `.env.local` and fill in REAL values locally / in your host's secret
# store. NEVER commit real secrets. The build itself needs NO secrets (catalogue
# is bundled); these are only for the server-side lead API + optional tracking.
# ════════════════════════════════════════════════════════════════════════════

# ── Supabase (lead capture) ──────────────────────────────────────────────────
# Public project URL. Safe to expose to the browser (NEXT_PUBLIC_*).
# Project ref: orzitfqmlvopujsoyigr
NEXT_PUBLIC_SUPABASE_URL=https://orzitfqmlvopujsoyigr.supabase.co

# Service-role key — SERVER ONLY. Used by /api/lead + /api/rights to INSERT into
# public.leads / public.data_subject_requests (bypasses RLS), and by
# /api/analyze-bill to enforce the per-IP/day rate-limit guard against
# public.bill_analyses. MUST NOT be prefixed NEXT_PUBLIC_ and MUST NEVER reach the
# browser. Leave blank in any client-exposed context.
SUPABASE_SERVICE_ROLE_KEY=

# Anon (publishable) key — PUBLIC, RLS-gated, safe to expose. OPTIONAL: only used
# by /api/analyze-bill as the apikey forwarded to the site-bill-analyzer edge
# function (verify_jwt:false, so the call works without it too).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Meta (Facebook) Pixel — OPTIONAL ─────────────────────────────────────────
# Pixel id for the 'Lead' conversion event. If unset, Meta tracking no-ops.
NEXT_PUBLIC_FB_PIXEL_ID=

# ── Web Push (PWA notifications) — OPTIONAL ───────────────────────────────────
# Public VAPID key. The PWA push opt-in (<PwaInstaller>) is shown ONLY when this
# is set; with it unset the whole push UI fail-soft no-ops (the offline service
# worker + AI concierge still work). Generate a key pair with:
#   npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# Private VAPID key — used by the BACKEND push sender (site-push-notify edge fn),
# NOT by this web app. Listed for reference; never expose it to the browser.
# VAPID_PRIVATE_KEY=

# ── Edge-function proxy targets — OPTIONAL ────────────────────────────────────
# /api/ai-chat forwards to site-ai-chat and /api/push forwards to
# site-push-notify. Override the function names here for a different deployment;
# both also use NEXT_PUBLIC_SUPABASE_ANON_KEY above as the forwarded apikey.
# SITE_AI_CHAT_FN=site-ai-chat
# SITE_PUSH_NOTIFY_FN=site-push-notify
